/* 
This script to remote ssh login and inside that remote server we further do ssh login
*/


connect 'xx.xxx.xx.xx /ssh /2 /auth=password /user=user /passwd=user'
wait '$'
sendln "ssh second.ssh.username@xx.xxx.xxx.xx"
;wait '(yes/no/[fingerprint])? '
;sendln "yes"
wait 's password: '
sendln "password"
wait '$'
sendln "bash"