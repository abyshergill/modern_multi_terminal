; =======================================================
; Telnet Automated Login Script (.ttl)
; =======================================================

; Syntax: connect '<Target_IP> /telnet /port=<Port_Number>'
connect '192.168.1.50 /telnet /port=23'

wait 'Username:'
sendln "admin"

wait 'Password:'
sendln "secretpass123"

wait '#'
sendln "show system uptime"

end